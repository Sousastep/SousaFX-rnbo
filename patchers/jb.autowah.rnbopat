                    "rnbo_extra_attributes": {
                        "exposeparams": 0,
                        "gencode": "ExponentialEaseIn(value) {\n\treturn value == 0 ? value : pow(1.93, 10 * ((value - 1)));\n}\n\nk35_lp(xin, cf, q) {\n\tHistory z1(0);\n\tHistory z2(0);\n\tHistory z3(0);\n\tHistory S35(0);\n\tT = 1 / samplerate;\n\tT_div_two = T / 2;\n\ttwo_div_T = 2 / T;\n\twd = twopi * cf;\n\twa = two_div_T * (tan(wd * T_div_two));\n\tg = wa * T_div_two;\n\tG = g / ((1 + g));\n\tK = 0.01 + (((2 - 0.01)) * (q / 10));\n\tlpf2_beta = ((K - (K * G))) / ((1 + g));\n\thpf1_beta = (-1) / ((1 + g));\n\talpha = 1 / (((1 - (K * G)) + (((K * G)) * G)));\n\tv1 = ((xin - z1)) * G;\n\tlp1 = v1 + z1;\n\tz1 = lp1 + v1;\n\tu = alpha * ((lp1 + S35));\n\tv2 = ((u - z2)) * G;\n\tlp2 = v2 + z2;\n\tz2 = lp2 + v2;\n\ty = K * lp2;\n\tv3 = ((y - z3)) * G;\n\tlp3 = v3 + z3;\n\tz3 = lp3 + v3;\n\tS35 = (lpf2_beta * z2) + (hpf1_beta * z3);\n\treturn K > 0 ? y / K : y;\n}\n\nsvf_as(xin, cf, q) {\n\tHistory y0(0);\n\tHistory y1(0);\n\tHistory a1(0);\n\tHistory a2(0);\n\tHistory a3(0);\n\tg = tan(((cf * pi)) / samplerate);\n\tr = 1 / q;\n\ta1 = 1 / ((1 + (g * ((g + r)))));\n\ta2 = g * a1;\n\ta3 = g * a2;\n\tv3 = xin - y1;\n\tv1 = (a1 * y0) + (a2 * v3);\n\tv2 = ((y1 + (a2 * y0))) + (a3 * v3);\n\ty0 = (2 * v1) - y0;\n\ty1 = (2 * v2) - y1;\n\thp = ((xin - (r * v1))) - v2;\n\tnotch = ((((v2 + hp)) + xin)) - (r * v1);\n\tpeak = ((((v2 - hp) + (2 * v2))) - xin) + (r * v1);\n\tall = (((((v2 + hp)) - (r * v1)) + xin)) - (((2 * r)) * v1);\n\treturn v2, hp, v1, notch, peak, all;\n}\n\nzdf_diode(xin, cf, q, sat) {\n\tHistory z0(0);\n\tHistory z1(0);\n\tHistory z2(0);\n\tHistory z3(0);\n\tHistory a1(1);\n\tHistory a2(0.5);\n\tHistory a3(0.5);\n\tHistory a4(0.5);\n\tT = 1 / samplerate;\n\tT_div_two = T / 2;\n\ttwo_div_T = 2 / T;\n\twd = twopi * cf;\n\twa = two_div_T * (tan(wd * T_div_two));\n\tg = wa * T_div_two;\n\tg_one = 1 + g;\n\tG4 = ((0.5 * g)) / g_one;\n\tG3 = ((0.5 * g)) / ((g_one - (((0.5 * g)) * G4)));\n\tG2 = ((0.5 * g)) / ((g_one - (((0.5 * g)) * G3)));\n\tG1 = g / ((g_one - (g * G2)));\n\tGAMMA = ((((G4 * G3)) * G2)) * G1;\n\tSG1 = ((G4 * G3)) * G2;\n\tSG2 = G4 * G3;\n\tSG3 = G4;\n\tSG4 = 1;\n\talpha = g / g_one;\n\tbeta1 = 1 / ((g_one - (g * G2)));\n\tbeta2 = 1 / ((g_one - (((0.5 * g)) * G3)));\n\tbeta3 = 1 / ((g_one - (((0.5 * g)) * G4)));\n\tbeta4 = 1 / g_one;\n\tgamma1 = ((1 + G1)) + G2;\n\tgamma2 = 1 + (G2 * G3);\n\tgamma3 = 1 + (G3 * G4);\n\tdelta1 = g;\n\tdelta3 = 0.5 * g;\n\tdelta2 = delta3;\n\tepsilon1 = G2;\n\tepsilon2 = G3;\n\tepsilon3 = G4;\n\tfb4 = beta4 * z3;\n\tfb3 = beta3 * ((z2 + (fb4 * delta3)));\n\tfb2 = beta2 * ((z1 + (fb3 * delta2)));\n\tfbo1 = beta1 * ((z0 + (fb2 * delta1)));\n\tfbo2 = beta2 * ((z1 + (fb3 * delta2)));\n\tfbo3 = beta3 * ((z2 + (fb4 * delta3)));\n\tSIGMA = (((((SG1 * fbo1) + (SG2 * fbo2))) + (SG3 * fbo3))) + (SG4 * fb4);\n\txin_tanh = (1 / (tanh(sat))) * (tanh(sat * xin));\n\tun = ((xin_tanh - (q * SIGMA))) / ((1 + (q * GAMMA)));\n\tvin = (((un * gamma1) + fb2)) + (epsilon1 * fbo1);\n\tv = (((a1 * vin) - z0)) * alpha;\n\tlp = v + z0;\n\tz0 = lp + v;\n\tvin_1 = (((lp * gamma2) + fb3)) + (epsilon2 * fbo2);\n\tv_2 = (((a2 * vin_1) - z1)) * alpha;\n\tlp_3 = v_2 + z1;\n\tz1 = lp_3 + v_2;\n\tvin_4 = (((lp_3 * gamma3) + fb4)) + (epsilon3 * fbo3);\n\tv_5 = (((a3 * vin_4) - z3)) * alpha;\n\tlp_6 = v_5 + z3;\n\tz3 = lp_6 + v_5;\n\tv_7 = (((a4 * lp_6) - z3)) * alpha;\n\tlp_8 = v_7 + z3;\n\tz3 = lp_8 + v_7;\n\treturn lp_8;\n}\n\nexpr_9 = ExponentialEaseIn(in2);\nfloat_10 = float(0.1);\ngate_11, gate_12, gate_13 = gate(in4, in1, choices=3);\nclamp_14 = clamp(in3, 0, 1);\nmul_15 = expr_9 * 9680;\nadd_16 = mul_15 + 20;\nclamp_17 = clamp(add_16, 20, 9700);\nlimit = (samplerate / 2) - 25;\ncf = clip(clamp_17, 0, limit);\nq = (clip(clamp_14, 0, 1)) * 10;\nexpr_18 = k35_lp(gate_11, cf, q);\ngen_19 = expr_18;\nlimit_20 = samplerate / 2;\ncf_21 = clip(clamp_17, 0, limit_20);\nq_22 = ((clip(clamp_14, 0, 1)) * 20) + 0.5;\nexpr_23, expr_24, expr_25, expr_26, expr_27, expr_28 = svf_as(gate_12, cf_21, q_22);\ngen_29 = expr_24;\ngen_30 = expr_26;\ngen_31 = expr_23;\ngen_32 = expr_25;\ngen_33 = expr_27;\ngen_34 = expr_28;\nlimit_35 = samplerate / 3;\ncf_36 = clip(clamp_17, 0, limit_35);\nq_37 = (clip(clamp_14, 0, 1)) * 19;\nsat = ((clip(float_10, 0, 1)) * 30) + 0.001;\nexpr_38 = zdf_diode(gate_13, cf_36, q_37, sat);\ngen_39 = expr_38;\nselector_40 = selector(in4, gen_19, gen_31, gen_39);\nout1 = selector_40;",
