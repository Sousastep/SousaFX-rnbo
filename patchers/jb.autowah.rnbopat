                        "gencode": "History pos(0);\nHistory vel(0);\ntarget = in1;\nmass = in2;\nstiffness = in3;\ndamping = in4;\nthresh = in5;\ngate = in6;\ndelta = 1 / samplerate;\nmass_safe = max(mass, 1e-09);\nstiff_safe = max(stiffness, 0);\ndamp_safe = max(damping, 0);\nthresh_safe = max(thresh, 1e-09);\nerr = pos - target;\nacc = ((((-stiff_safe) * err) - (damp_safe * vel))) / mass_safe;\nvnext = vel + (acc * delta);\nxnext = pos + (vnext * delta);\nstopped = (((abs(err)) < thresh_safe)) * (((abs(vnext)) < thresh_safe));\nfreeze = clamp(stopped + (1 - gate), 0, 1);\nvel = ((1 - freeze)) * vnext;\npos = (freeze * pos) + (((1 - freeze)) * xnext);\nexpr_1 = pos;\nout1 = expr_1;",
                        "geninlets": 6,
