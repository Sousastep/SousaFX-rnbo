                                {
                                    "box": {
                                        "maxclass": "codebox",
                                        "patching_rect": [ 168.0, 143.0, 880.0, 682.0 ],
                                        "fontname": "<Monospaced>",
                                        "numinlets": 6,
                                        "numoutlets": 1,
                                        "fontface": 0,
                                        "outlettype": [ "" ],
                                        "id": "obj-5",
                                        "fontsize": 12.0,
                                        "code": "// State variables\nHistory pos(0);\nHistory vel(0);\r\n\r\n// Inputs assigned to audio-rate inlets\ntarget    = in1; // Target position\nmass      = in2; // Mass of the object\nstiffness = in3; // Spring constant\ndamping   = in4; // Friction/damping\nthresh    = in5; // Stopping threshold\ngate      = in6; // 1 = run, 0 = freeze\n\ndelta = 1 / samplerate;\r\n\n// Safety constraints for audio-rate modulation\nmass_safe   = max(mass, 1e-9); // Prevent division by zero\nstiff_safe  = max(stiffness, 0);\ndamp_safe   = max(damping, 0);\nthresh_safe = max(thresh, 1e-9);\n\n// Calculate error and acceleration\nerr = pos - target;\nacc = (-stiff_safe * err - damp_safe * vel) / mass_safe;\n\n// Semi-implicit Euler integration\nvnext = vel + acc * delta;\nxnext = pos + vnext * delta;\n\n// Stopping condition (logic high when close to target and moving slowly)\nstopped = (abs(err) < thresh_safe) * (abs(vnext) < thresh_safe);\n\n// Freeze mask: 1 = stay still, 0 = update\n// Triggered by the 'stopped' logic OR the external gate inlet\nfreeze = clamp(stopped + (1 - gate), 0, 1);\n\n// Apply state updates\nvel = (1 - freeze) * vnext; \npos = (freeze * pos) + ((1 - freeze) * xnext);\n\n// Main Output\nout1 = pos;\n\n// Optional Outputs\n// out2 = vel;\n// out3 = stopped;"
                                    }
                                },
                                {
                                    "box": {
                                        "maxclass": "newobj",
                                        "text": "out 1",
                                        "patching_rect": [ 168.0, 862.0, 35.0, 22.0 ],
                                        "numinlets": 1,
                                        "numoutlets": 0,
                                        "id": "obj-4"
                                    }
                                }
                            ],
                            "lines": [
                                {
                                    "patchline": {
                                        "source": [ "obj-8", 0 ],
                                        "destination": [ "obj-5", 5 ]
                                    }
