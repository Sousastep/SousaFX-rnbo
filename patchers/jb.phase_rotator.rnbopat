            {
                "box": {
                    "genpatcher": {
                        "patcher": {
                            "fileversion": 1,
                            "appversion": {
                                "major": 9,
                                "minor": 1,
                                "revision": 4,
                                "architecture": "x64",
                                "modernui": 1
                            },
                            "classnamespace": "dsp.gen",
                            "rect": [ 548.0, 253.0, 662.0, 833.0 ],
                            "boxes": [
                                {
                                    "box": {
                                        "maxclass": "comment",
                                        "text": "broadcast-style phase rotation to even out the tuba's asymmetrical waveform. Should this have a UI? maybe.",
                                        "linecount": 3,
                                        "patching_rect": [ 83.0, 34.5, 221.0, 47.0 ],
                                        "numoutlets": 0,
                                        "id": "obj-11",
                                        "numinlets": 1
                                    }
                                },
                                {
                                    "box": {
                                        "maxclass": "newobj",
                                        "text": "in 3 @comment allpass_Q",
                                        "patching_rect": [ 353.0, 131.0, 149.0, 22.0 ],
                                        "numoutlets": 1,
                                        "outlettype": [ "" ],
                                        "id": "obj-10",
                                        "numinlets": 0
                                    }
                                },
                                {
                                    "box": {
                                        "maxclass": "newobj",
                                        "text": "in 2 @comment allpass_freq_Hz",
                                        "patching_rect": [ 200.0, 96.0, 182.0, 22.0 ],
                                        "numoutlets": 1,
                                        "outlettype": [ "" ],
                                        "id": "obj-8",
                                        "numinlets": 0
                                    }
                                },
                                {
                                    "box": {
                                        "maxclass": "comment",
                                        "text": "allpass from Simper's implementation in ess's repo\n\nhttps://github.com/ess-m/gen-filters",
                                        "linecount": 3,
                                        "patching_rect": [ 102.0, 677.0, 286.0, 47.0 ],
                                        "numoutlets": 0,
                                        "id": "obj-9",
                                        "numinlets": 1
                                    }
                                },
                                {
                                    "box": {
                                        "maxclass": "codebox",
                                        "patching_rect": [ 47.0, 164.0, 325.0, 500.0 ],
                                        "fontsize": 12.0,
                                        "numoutlets": 1,
                                        "fontname": "<Monospaced>",
                                        "outlettype": [ "" ],
                                        "fontface": 0,
                                        "id": "obj-5",
                                        "numinlets": 3,
                                        "code": "svf_ap(xin, cf, q) {\n    History y0(0), y1(0);\n\n    g = tan(cf * pi / samplerate);\n    r = 1 / q;\n\n    a1 = 1 / (1 + g * (g + r));\n    a2 = g * a1;\n    a3 = g * a2;\n\n    v3 = xin - y1;\n    v1 = a1 * y0 + a2 * v3;\n    v2 = y1 + a2 * y0 + a3 * v3;\n\n    y0 = 2 * v1 - y0;\n    y1 = 2 * v2 - y1;\n\n    lp = v2;\n    bp = v1;\n    hp = xin - r * v1 - v2;\n\n    return lp + hp - r * bp;\n}\n\nlimit = samplerate / 2;\n\ncf = clip(in2, 0, limit);\nq = clip(in3, 0, 1) * 20 + 0.5;\n\nout1 = svf_ap(in1, cf, q);"
                                    }
                                },
                                {
                                    "box": {
                                        "maxclass": "newobj",
                                        "text": "in 1",
                                        "patching_rect": [ 47.0, 47.0, 28.0, 22.0 ],
                                        "numoutlets": 1,
                                        "outlettype": [ "" ],
                                        "id": "obj-1",
                                        "numinlets": 0
                                    }
                                },
                                {
                                    "box": {
                                        "maxclass": "newobj",
                                        "text": "out 1",
                                        "patching_rect": [ 47.0, 702.0, 35.0, 22.0 ],
                                        "numoutlets": 0,
                                        "id": "obj-4",
                                        "numinlets": 1
                                    }
                                }
