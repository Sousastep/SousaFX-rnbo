            {
                "box": {
                    "code": "// Transparent cubic soft saturator\r\n\n@param({ min: 0.0, max: 1.0 }) drive = 0.12;\nlet blend = in2;\n\n// Map drive (0.0–1.0) to gain multiplier (1.0–4.0)\nlet gain = 1.0 + (drive * 3.0);\n\nlet dry = in1;\nlet pushed = dry * gain;\n\nlet wet = 0.0;\n\n// Cubic soft clip: y = x - x³/3\n// Clamped outside |x| > 1.0 (peak output 2/3)\nif (pushed > 1.0) {\n    wet = 2.0 / 3.0;\n} else if (pushed < -1.0) {\n    wet = -(2.0 / 3.0);\n} else {\n    wet = pushed - (pushed * pushed * pushed) / 3.0;\n}\n\n// Compensate for gain so output is approximately unity\nwet = wet / gain;\n\n// Parallel blend of dry and shaped signal\nout1 = (dry * (1.0 - blend)) + (wet * blend);",
                    "fontface": 0,
                    "fontname": "<Monospaced>",
                    "fontsize": 12.0,
                    "id": "obj-21",
                    "maxclass": "codebox~",
                    "numinlets": 2,
                    "numoutlets": 1,
                    "outlettype": [ "signal" ],
                    "patching_rect": [ 911.0, 2433.0, 569.0, 478.0 ],
                    "rnbo_classname": "codebox~",
                    "rnbo_extra_attributes": {
                        "nocache": 0,
                        "code": "// Transparent cubic soft saturator\r\n\n@param({ min: 0.0, max: 1.0 }) drive = 0.12;\nlet blend = in2;\n\n// Map drive (0.0–1.0) to gain multiplier (1.0–4.0)\nlet gain = 1.0 + (drive * 3.0);\n\nlet dry = in1;\nlet pushed = dry * gain;\n\nlet wet = 0.0;\n\n// Cubic soft clip: y = x - x³/3\n// Clamped outside |x| > 1.0 (peak output 2/3)\nif (pushed > 1.0) {\n    wet = 2.0 / 3.0;\n} else if (pushed < -1.0) {\n    wet = -(2.0 / 3.0);\n} else {\n    wet = pushed - (pushed * pushed * pushed) / 3.0;\n}\n\n// Compensate for gain so output is approximately unity\nwet = wet / gain;\n\n// Parallel blend of dry and shaped signal\nout1 = (dry * (1.0 - blend)) + (wet * blend);",
                        "expr": "",
                        "safemath": 1
                    },
                    "rnbo_serial": 10,
                    "rnbo_uniqueid": "codebox~_obj-21",
