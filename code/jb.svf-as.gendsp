            {
                "box": {
                    "code": "/* SVF structure by Andrew Simper\r\n * Low, with bounded terms\n * https://cytomic.com/files/dsp/SvfLinearTrapOptimised2.pdf\r\n * stable cf between 0 .. sr/2\r\n * modified with Claude: https://claude.ai/share/e9c56f41-4400-4ba1-8c01-31d7f1fdbfed\r\n * & https://claude.ai/share/5e4e2ca1-0dea-4457-8526-4e41f7e50cd0\r\n */\n\nsvf_lp(xin, cf, q) {\n    History y0(0), y1(0);\n\n    g  = tan(cf * PI / samplerate);\n    r  = 1.0 / q;\n    a1 = 1.0 / (1.0 + g * (g + r));\n    a2 = g * a1;\n    a3 = g * a2;\n\n    v1 = a1 * y0 + a2 * (xin - y1);\n    v2 = y1 + a2 * y0 + a3 * (xin - y1);\n\n    y0 = 2.0 * v1 - y0;\n    y1 = 2.0 * v2 - y1;\n\n    return v2 * clip(r, 0.0, 1.0);\n}\n\ncf = clip(in2, 1.0, samplerate * 0.499);\nq  = clip(in3, 0.5, 20.5);\n\nstage1 = svf_lp(in1, cf, q);\nout1   = svf_lp(stage1, cf, q);\n",
                    "fontface": 0,
                    "fontname": "<Monospaced>",
                    "fontsize": 12.0,
                    "id": "obj-5",
                    "maxclass": "codebox",
                    "numinlets": 3,
                    "numoutlets": 1,
                    "outlettype": [ "" ],
                    "patching_rect": [ 15.0, 53.0, 570.0, 622.0 ]
                }
            }
        ],
